{
  "name": "microservice-arc",
  "version": "1.0.0",
  "description": "Precision reminder microservice for Calls, WhatsApp, BDA & Discord — Express + MongoDB",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "node --test tests/**/*.test.js",
    "test:unit": "node --test tests/unit/*.test.js",
    "test:integration": "node --test tests/integration/*.test.js",
    "health": "curl -s http://localhost:4000/health | node -e \"process.stdin.resume();process.stdin.on('data',d=>console.log(JSON.parse(d)))\""
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "express": "^4.21.2",
    "cors": "^2.8.5",
    "compression": "^1.7.5",
    "mongoose": "^8.16.0",
    "twilio": "^5.9.0",
    "axios": "^1.10.0",
    "luxon": "^3.7.2",
    "pino": "^9.6.0",
    "dotenv": "^16.5.0"
  },
  "devDependencies": {}
}

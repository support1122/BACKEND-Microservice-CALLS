# Microservice-ARC uses the parent backend's .env automatically.
# Override any variable here if needed.

PORT=4000

# MongoDB (same as parent)
# MONGODB_URI=mongodb+srv://...

# Twilio
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM=

# WATI (WhatsApp)
# WATI_API_BASE_URL=
# WATI_API_TOKEN=
# WATI_TENANT_ID=
# WATI_CHANNEL_NUMBER=

# Discord Webhooks
# DISCORD_HOT_LEAD_WEBHOOK_URL=
# DISCORD_REMINDER_CALL_WEBHOOK_URL=
# DISCORD_MEET_2MIN_WEBHOOK_URL=
# DISCORD_BDA_ATTENDANCE_WEBHOOK_URL=
# DISCORD_BDA_ABSENT_WEBHOOK_URL=
# DISCORD_BDA_DURATION_WEBHOOK_URL=

# Scheduler Tuning
# DISCORD_MEET_REMINDER_OFFSET_MINUTES=5
# UNIFIED_SCHEDULER_POLL_MS=30000
# SCHEDULER_STUCK_PROCESSING_MS=120000
# REMINDER_DRIFT_WARN_MS=5000
